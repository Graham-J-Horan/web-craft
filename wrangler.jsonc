{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webcraft-v2",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",  
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}