---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/hero-image.jpg";
import logo from "../assets/web_craft_logo.svg";

// Trade list with individual emojis — no more universal wrench
const trades = [
  { label: "Plumber", emoji: "🔧" },
  { label: "Electrician", emoji: "⚡" },
  { label: "Solicitor", emoji: "⚖️" },
  { label: "Accountant", emoji: "📊" },
  { label: "Photographer", emoji: "📷" },
  { label: "Personal Trainer", emoji: "💪" },
  { label: "Artist", emoji: "🎨" },
  { label: "Restaurant", emoji: "🍽️" },
  { label: "Dentist", emoji: "🦷" },
  { label: "Architect", emoji: "📐" },
];

const goals = [
  {
    value: "emergency",
    emoji: "📞",
    label: "Get phone calls",
    desc: "Emergency & direct contact",
  },
  {
    value: "bookings",
    emoji: "📅",
    label: "Take bookings",
    desc: "Online scheduling & reservations",
  },
  {
    value: "showcase",
    emoji: "🖼️",
    label: "Showcase work",
    desc: "Portfolio & project gallery",
  },
  {
    value: "leads",
    emoji: "💬",
    label: "Generate leads",
    desc: "Quotes, enquiries & callbacks",
  },
];

const vibes = [
  {
    value: "dark-bold",
    gradient: "from-[#0f1117] to-[#10b981]",
    swatchText: "#fff",
    label: "Dark & Bold",
    desc: "High contrast · powerful",
  },
  {
    value: "clean-minimal",
    gradient: "from-white to-[#e2e8f0]",
    swatchText: "#1c1b1b",
    label: "Clean & Minimal",
    desc: "Airy · Scandinavian",
  },
  {
    value: "warm-friendly",
    gradient: "from-[#fdf8f3] to-[#d97706]",
    swatchText: "#92400e",
    label: "Warm & Friendly",
    desc: "Approachable · local",
  },
  {
    value: "luxury-premium",
    gradient: "from-[#0a0a0a] to-[#d4a843]",
    swatchText: "#faf8f5",
    label: "Luxury & Premium",
    desc: "Editorial · refined",
  },
];
---

<Layout
  title="WebCraft — Your Website, Designed by AI. Built by Us."
  description="Answer 4 questions. Get a bespoke AI-generated website mockup for your trade in seconds. No credit card. No obligation."
>
  <!-- ═══════════════════════════════════════════
       NAV
  ════════════════════════════════════════════ -->
  <nav
    aria-label="Main navigation"
    class="fixed top-0 w-full z-50 glass border-b border-[var(--outline-variant)]/10 flex justify-between items-center px-6 md:px-10"
    style="height:72px;"
  >
    <!-- Logo as non-link — it's the current page -->
    <span aria-current="page">
      <img src={logo.src} alt="WebCraft Logo" class="h-12 w-auto" />
    </span>

    <div
      class="hidden md:flex items-center gap-8 font-body text-sm"
      role="list"
    >
      <a
        href="#how-it-works"
        class="text-[var(--on-surface-variant)] hover:text-[var(--on-surface)] transition-colors"
        role="listitem"
      >
        How it works
      </a>
      <a
        href="#generate"
        class="text-[var(--on-surface-variant)] hover:text-[var(--on-surface)] transition-colors"
        role="listitem"
      >
        Generate
      </a>
      <a
        href="/about"
        class="text-[var(--on-surface-variant)] hover:text-[var(--on-surface)] transition-colors"
        role="listitem"
      >
        About Us
      </a>
    </div>

    <button
      id="nav-build-btn"
      class="btn-glow px-5 py-2.5 rounded-full text-sm"
      aria-label="Scroll to the website generator"
    >
      Build My Site
    </button>
  </nav>

  <!-- ═══════════════════════════════════════════
       HERO
  ════════════════════════════════════════════ -->
  <header
    class="relative min-h-screen flex flex-col justify-center pt-[5.5rem] pb-16 px-6 md:px-10 overflow-hidden"
  >
    <!-- Background glows — decorative, hidden from AT -->
    <div
      aria-hidden="true"
      class="absolute top-1/4 -right-32 w-[600px] h-[600px] rounded-full bg-[var(--primary)]/8 blur-[140px] pointer-events-none"
    >
    </div>
    <div
      aria-hidden="true"
      class="absolute bottom-1/3 -left-32 w-[500px] h-[500px] rounded-full bg-[var(--secondary)]/8 blur-[120px] pointer-events-none"
    >
    </div>

    <div
      class="max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-16 items-center"
    >
      <!-- Copy -->
      <div class="relative z-10">
        <h1
          class="font-headline text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter leading-[1.0] md:leading-[0.95] mb-6"
        >
          Your website,<br />
          <span class="grad-primary">designed by AI</span><br />
          built by us.
        </h1>

        <p
          class="text-[var(--on-surface-variant)] text-lg max-w-md mb-10 leading-relaxed"
        >
          Answer 4 questions. Get a bespoke website mockup generated for your
          business in seconds. Love it — lock it in and receive your
          no-obligation proposal within 72 hours.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <button
            id="hero-generate-btn"
            class="btn-glow px-8 py-4 rounded-full text-base"
            aria-label="Scroll to the website generator form"
          >
            Generate My Website →
          </button>
          <a
            href="/testimonials"
            class="btn-ghost px-8 py-4 rounded-full justify-center"
            aria-label="View our client stories and results"
          >
            See results
          </a>
        </div>

        <div
          class="flex items-center gap-2 text-xs font-bold text-[var(--secondary)] uppercase tracking-widest mb-12"
        >
          <span class="flex h-2 w-2 relative">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--primary)] opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-[var(--primary)]"
            ></span>
          </span>
          Only 3 proposal slots left for this week
        </div>

        <!-- Trust strip -->
        <ul
          class="flex flex-wrap items-center gap-6 text-sm text-[var(--on-surface-variant)]"
          aria-label="Key promises"
        >
          <li class="flex items-center gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--tertiary)"
              stroke-width="2.5"
              aria-hidden="true"
              ><polyline points="20 6 9 17 4 12"></polyline></svg
            >
            No credit card
          </li>
          <li class="flex items-center gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--tertiary)"
              stroke-width="2.5"
              aria-hidden="true"
              ><polyline points="20 6 9 17 4 12"></polyline></svg
            >
            72hr proposal
          </li>
          <li class="flex items-center gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--tertiary)"
              stroke-width="2.5"
              aria-hidden="true"
              ><polyline points="20 6 9 17 4 12"></polyline></svg
            >
            No obligation
          </li>
        </ul>
      </div>

      <!-- Hero Media -->
      <div class="relative hidden lg:block" aria-hidden="true">
        <div
          class="absolute -inset-8 bg-gradient-to-tr from-[var(--primary)]/15 to-[var(--tertiary)]/10 blur-3xl rounded-full pointer-events-none"
        >
        </div>
        <div
          class="relative bg-[var(--surface-container-high)] rounded-[1.5rem] p-3 shadow-2xl border border-[var(--outline-variant)]/10 transform rotate-1 hover:rotate-0 transition-transform duration-700"
        >
          <div class="rounded-xl overflow-hidden aspect-[16/10] relative">
            <Image
              src={heroImage}
              alt="Designer working on a high-end website mockup"
              class="w-full h-full object-cover"
              loading="eager"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-[var(--surface)]/40 to-transparent"
            >
            </div>
          </div>
        </div>
        <div
          class="float-1 absolute -bottom-6 -left-6 glass-light border border-[var(--outline-variant)]/15 p-4 rounded-2xl shadow-xl"
        >
          <div
            class="text-xs text-[var(--on-surface-variant)] mb-1 font-bold uppercase tracking-wide"
          >
            Generated in
          </div>
          <div class="font-headline text-2xl font-bold text-[var(--tertiary)]">
            12s
          </div>
        </div>
        <div
          class="float-2 absolute -top-4 -right-4 glass-light border border-[var(--outline-variant)]/15 p-3 rounded-xl shadow-xl"
        >
          <div class="text-xs text-[var(--on-surface-variant)] font-bold">
            ✦ Bespoke to your trade
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════
       HOW IT WORKS
  ════════════════════════════════════════════ -->
  <section
    id="how-it-works"
    aria-labelledby="how-heading"
    class="py-28 px-6 md:px-10 bg-[var(--surface-container-low)] relative overflow-hidden"
  >
    <div
      aria-hidden="true"
      class="absolute top-0 right-1/4 w-96 h-96 bg-[var(--secondary)]/6 blur-[120px] rounded-full pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto">
      <div class="mb-16 reveal-on-scroll">
        <p
          class="text-[var(--tertiary)] text-xs font-bold uppercase tracking-[0.2em] mb-4"
          aria-hidden="true"
        >
          The Process
        </p>
        <h2
          id="how-heading"
          class="font-headline text-4xl md:text-5xl font-bold mb-5"
        >
          From idea to proposal<br /><span class="grad-primary"
            >in five steps.</span
          >
        </h2>
        <p class="text-[var(--on-surface-variant)] text-lg max-w-lg">
          No designers, no briefs, no back-and-forth. Just your answers — and a
          website that feels made for you.
        </p>
      </div>

      <ol
        class="grid grid-cols-1 md:grid-cols-12 gap-5 list-none"
        aria-label="Five step process"
      >
        <li
          class="md:col-span-7 process-card bg-[var(--surface-container)] rounded-[1.75rem] p-9 relative overflow-hidden reveal-on-scroll"
          style="transition-delay:0.05s"
        >
          <div class="relative z-10">
            <span
              class="font-headline text-7xl font-black text-[var(--primary)] opacity-[0.12] block mb-4 select-none"
              aria-hidden="true">01</span
            >
            <h3 class="font-headline text-2xl font-bold mb-3">
              Your Trade &amp; Name
            </h3>
            <p
              class="text-[var(--on-surface-variant)] leading-relaxed max-w-sm"
            >
              Tell us your industry and business name. Our AI cross-references
              thousands of high-performing websites in your niche to understand
              what works — before a pixel is placed.
            </p>
          </div>
          <div class="mt-8 flex gap-2 flex-wrap" aria-hidden="true">
            <span
              class="px-3 py-1.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] text-xs font-bold"
              >Plumber</span
            >
            <span
              class="px-3 py-1.5 rounded-full bg-[var(--secondary)]/10 text-[var(--secondary)] text-xs font-bold"
              >Solicitor</span
            >
            <span
              class="px-3 py-1.5 rounded-full bg-[var(--tertiary)]/10 text-[var(--tertiary)] text-xs font-bold"
              >Photographer</span
            >
            <span
              class="px-3 py-1.5 rounded-full bg-[var(--surface-container-highest)] text-[var(--on-surface-variant)] text-xs font-bold"
              >+ more</span
            >
          </div>
          <div
            aria-hidden="true"
            class="absolute top-0 right-0 w-40 h-full bg-gradient-to-l from-[var(--primary)]/5 to-transparent rounded-r-[1.75rem] pointer-events-none"
          >
          </div>
        </li>

        <li
          class="md:col-span-5 process-card bg-[var(--surface-container-high)] rounded-[1.75rem] p-9 flex flex-col justify-between border border-[var(--outline-variant)]/5 reveal-on-scroll"
          style="transition-delay:0.1s"
        >
          <div>
            <span
              class="font-headline text-7xl font-black text-[var(--secondary)] opacity-[0.12] block mb-4 select-none"
              aria-hidden="true">02</span
            >
            <h3 class="font-headline text-2xl font-bold mb-3">
              Your Visual Style
            </h3>
            <p class="text-[var(--on-surface-variant)] leading-relaxed">
              Dark &amp; bold. Clean &amp; minimal. Warm &amp; friendly. Luxury.
              Your vibe shapes every colour, font, and layout decision the AI
              makes.
            </p>
          </div>
          <div class="flex gap-3 mt-7" aria-hidden="true">
            <div
              class="w-9 h-9 rounded-full bg-gradient-to-br from-[#0f1117] to-[#059669] shadow-lg"
            >
            </div>
            <div
              class="w-9 h-9 rounded-full bg-gradient-to-br from-white to-[#e2e8f0] shadow-lg"
            >
            </div>
            <div
              class="w-9 h-9 rounded-full bg-gradient-to-br from-[#fdf8f3] to-[#d97706] shadow-lg"
            >
            </div>
            <div
              class="w-9 h-9 rounded-full bg-gradient-to-br from-[#0a0a0a] to-[#d4a843] shadow-lg"
            >
            </div>
          </div>
        </li>

        <li
          class="md:col-span-4 process-card bg-[var(--surface-container)] rounded-[1.75rem] p-9 flex flex-col justify-between reveal-on-scroll"
          style="transition-delay:0.15s"
        >
          <div>
            <span
              class="font-headline text-7xl font-black text-[var(--tertiary)] opacity-[0.12] block mb-4 select-none"
              aria-hidden="true">03</span
            >
            <h3 class="font-headline text-2xl font-bold mb-3">Your Goal</h3>
            <p class="text-[var(--on-surface-variant)] leading-relaxed">
              Emergency calls, online bookings, portfolio showcase, or lead
              generation? The goal shapes the hero, the CTA, and the entire
              conversion architecture.
            </p>
          </div>
          <div
            class="mt-6 bg-[var(--surface-container-high)] rounded-xl p-3 text-xs text-[var(--on-surface-variant)]"
            aria-hidden="true"
          >
            <span class="text-[var(--tertiary)] font-bold">→</span> CTA &amp; layout
            adapt to your goal
          </div>
        </li>

        <li
          class="md:col-span-4 process-card bg-[var(--surface-container-high)] rounded-[1.75rem] p-9 flex flex-col justify-between border border-[var(--outline-variant)]/5 reveal-on-scroll"
          style="transition-delay:0.2s"
        >
          <div>
            <span
              class="font-headline text-7xl font-black opacity-[0.12] block mb-4 select-none"
              style="color:#10b981"
              aria-hidden="true">04</span
            >
            <h3 class="font-headline text-2xl font-bold mb-3">Your Edge</h3>
            <p class="text-[var(--on-surface-variant)] leading-relaxed">
              One sentence. What makes you different? Price, speed, experience,
              a guarantee. This goes into your hero headline — in your words,
              not a template's.
            </p>
          </div>
          <div
            class="mt-6 bg-[var(--secondary-dim)]/20 border border-[var(--secondary-dim)]/30 rounded-xl p-3 text-xs text-[var(--secondary)] font-bold"
            aria-hidden="true"
          >
            "Fastest callout in Dublin"
          </div>
        </li>

        <li
          class="md:col-span-4 process-card bg-[var(--surface-container)] rounded-[1.75rem] p-9 flex flex-col justify-between reveal-on-scroll"
          style="transition-delay:0.25s"
        >
          <div>
            <span
              class="font-headline text-7xl font-black text-[var(--primary)] opacity-[0.12] block mb-4 select-none"
              aria-hidden="true">05</span
            >
            <h3 class="font-headline text-2xl font-bold mb-3">
              Generate &amp; Lock
            </h3>
            <p class="text-[var(--on-surface-variant)] leading-relaxed">
              Hit generate. See your bespoke mockup. Regenerate if you want to.
              When it clicks — lock it in. Your no-obligation proposal arrives
              in 72 hours.
            </p>
          </div>
          <button
            id="steps-generate-btn"
            class="btn-glow mt-6 px-5 py-3 rounded-xl text-sm"
            aria-label="Scroll to the generator and try it now"
          >
            Try it now →
          </button>
        </li>
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       GENERATE FORM
  ════════════════════════════════════════════ -->
  <section
    id="generate"
    aria-labelledby="generate-heading"
    class="py-28 px-6 md:px-10 relative overflow-hidden"
  >
    <div
      aria-hidden="true"
      class="absolute top-0 left-1/3 w-96 h-96 bg-[var(--primary)]/8 blur-[140px] rounded-full pointer-events-none"
    >
    </div>
    <div
      aria-hidden="true"
      class="absolute bottom-0 right-1/4 w-80 h-80 bg-[var(--secondary)]/8 blur-[120px] rounded-full pointer-events-none"
    >
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14 reveal-on-scroll">
        <p
          class="text-[var(--tertiary)] text-xs font-bold uppercase tracking-[0.2em] mb-4"
          aria-hidden="true"
        >
          Generate Yours
        </p>
        <h2
          id="generate-heading"
          class="font-headline text-4xl md:text-5xl font-bold mb-5"
        >
          Four questions.<br /><span class="grad-primary"
            >One website, made for you.</span
          >
        </h2>
        <p class="text-[var(--on-surface-variant)] text-lg">
          Tell us about your business. We'll design something that actually
          looks like yours.
        </p>
      </div>

      <div
        class="glass border border-[var(--outline-variant)]/20 rounded-[2rem] p-8 md:p-10 reveal-on-scroll overflow-hidden"
        style="transition-delay:0.1s"
      >
        <!-- Live region for screen reader announcements -->
        <div
          id="sr-status"
          role="status"
          aria-live="polite"
          aria-atomic="true"
          class="sr-only"
        >
        </div>

        <!-- ── Q1: Trade ──────────────────────────────── -->
        <div class="mb-8" id="step-1">
          <fieldset>
            <legend
              class="block text-sm font-bold text-[var(--on-surface)] mb-4"
            >
              <span
                class="text-[var(--primary)] font-headline text-lg mr-2"
                aria-hidden="true">01</span
              >
              What's your trade or profession?
            </legend>

            <div
              class="flex flex-wrap gap-2"
              role="group"
              aria-label="Select your trade"
            >
              {
                trades.map((t) => (
                  <button
                    type="button"
                    class="trade-pill"
                    data-trade={t.label}
                    aria-pressed="false"
                    aria-label={`Select trade: ${t.label}`}
                  >
                    <span aria-hidden="true">{t.emoji}</span>
                    {t.label}
                  </button>
                ))
              }
            </div>

            <div class="mt-3">
              <label for="trade-other" class="field-label"
                >Or type your trade</label
              >
              <input
                type="text"
                id="trade-other"
                class="gen-input"
                placeholder="e.g. Florist, Yoga instructor..."
                maxlength="60"
                autocomplete="organization-title"
              />
            </div>
          </fieldset>
        </div>

        <!-- ── Q2: Business name — shown after trade selected ── -->
        <div class="mb-8 q-step" id="step-2" hidden>
          <fieldset>
            <legend
              class="block text-sm font-bold text-[var(--on-surface)] mb-3"
            >
              <span
                class="text-[var(--primary)] font-headline text-lg mr-2"
                aria-hidden="true">02</span
              >
              What's your business called?
              <span class="text-[var(--on-surface-variant)] font-normal ml-1"
                >(and where is it based?)</span
              >
            </legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label for="biz-name" class="field-label"
                  >Business name <span
                    class="text-[var(--error)]"
                    aria-hidden="true">*</span
                  ><span class="sr-only">(required)</span></label
                >
                <input
                  type="text"
                  id="biz-name"
                  name="businessName"
                  class="gen-input"
                  placeholder="e.g. AquaFix Plumbing"
                  maxlength="60"
                  required
                  autocomplete="organization"
                  aria-required="true"
                  aria-describedby="biz-name-error"
                />
                <p id="biz-name-error" class="field-error" role="alert">
                  Please enter your business name.
                </p>
              </div>
              <div>
                <label for="biz-location" class="field-label"
                  >Your city or region <span
                    class="text-[var(--error)]"
                    aria-hidden="true">*</span
                  ><span class="sr-only">(required)</span></label
                >
                <input
                  type="text"
                  id="biz-location"
                  name="location"
                  class="gen-input"
                  placeholder="e.g. Dublin"
                  maxlength="40"
                  required
                  autocomplete="address-level2"
                  aria-required="true"
                  aria-describedby="biz-loc-error"
                />
                <p id="biz-loc-error" class="field-error" role="alert">
                  Please enter your location.
                </p>
              </div>
            </div>
          </fieldset>
        </div>

        <!-- ── Q3: Goal — shown after name entered ─── -->
        <div class="mb-8 q-step" id="step-3" hidden>
          <fieldset>
            <legend
              class="block text-sm font-bold text-[var(--on-surface)] mb-4"
            >
              <span
                class="text-[var(--primary)] font-headline text-lg mr-2"
                aria-hidden="true">03</span
              >
              What do you most want your website to do?
            </legend>
            <div
              class="grid grid-cols-1 sm:grid-cols-2 gap-3"
              role="group"
              aria-label="Select your primary website goal"
            >
              {
                goals.map((g) => (
                  <label
                    class="choice-tile p-4 cursor-pointer"
                    data-goal={g.value}
                  >
                    <input
                      type="radio"
                      name="goal"
                      value={g.value}
                      class="sr-only"
                      aria-label={g.label}
                    />
                    <span class="text-xl mb-2 block" aria-hidden="true">
                      {g.emoji}
                    </span>
                    <span class="font-bold text-sm text-[var(--on-surface)] block">
                      {g.label}
                    </span>
                    <span class="text-xs text-[var(--on-surface-variant)] mt-1 block">
                      {g.desc}
                    </span>
                  </label>
                ))
              }
            </div>
          </fieldset>
        </div>

        <!-- ── Q4: Vibe — shown after goal selected ── -->
        <div class="mb-8 q-step" id="step-4" hidden>
          <fieldset>
            <legend
              class="block text-sm font-bold text-[var(--on-surface)] mb-4"
            >
              <span
                class="text-[var(--primary)] font-headline text-lg mr-2"
                aria-hidden="true">04</span
              >
              Pick the style that feels like you.
            </legend>
            <div
              class="grid grid-cols-2 gap-3"
              role="group"
              aria-label="Select a visual style"
            >
              {
                vibes.map((v) => (
                  <label
                    class="choice-tile overflow-hidden cursor-pointer"
                    data-vibe={v.value}
                  >
                    <input
                      type="radio"
                      name="vibe"
                      value={v.value}
                      class="sr-only"
                      aria-label={v.label}
                    />
                    <div
                      class={`h-16 bg-gradient-to-br ${v.gradient} flex items-end p-3`}
                      aria-hidden="true"
                    >
                      <span
                        class="text-xs font-bold"
                        style={`color:${v.swatchText}`}
                      >
                        Aa
                      </span>
                    </div>
                    <div class="p-3">
                      <span class="font-bold text-sm text-[var(--on-surface)] block">
                        {v.label}
                      </span>
                      <span class="text-xs text-[var(--on-surface-variant)]">
                        {v.desc}
                      </span>
                    </div>
                  </label>
                ))
              }
            </div>
          </fieldset>
        </div>

        <!-- ── Q5 (optional): USP + generate — shown after vibe ── -->
        <div class="q-step" id="step-5" hidden>
          <div class="mb-8">
            <label
              for="usp-input"
              class="block text-sm font-bold text-[var(--on-surface)] mb-2"
            >
              <span
                class="text-[var(--outline)] font-headline text-lg mr-2"
                aria-hidden="true">+</span
              >
              What makes you different?
              <span class="text-[var(--on-surface-variant)] font-normal ml-1"
                >(optional — makes the AI much sharper)</span
              >
            </label>
            <input
              type="text"
              id="usp-input"
              class="gen-input"
              placeholder='e.g. "Fastest response in the city" or "15 years, fully guaranteed"'
              maxlength="120"
            />
          </div>

          <!-- Error banner — replaces alert() -->
          <div
            id="gen-error-banner"
            class="error-banner mb-6"
            role="alert"
            aria-live="assertive"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              flex-shrink-0
              style="flex-shrink:0;margin-top:1px"
              ><circle cx="12" cy="12" r="10"></circle><line
                x1="12"
                y1="8"
                x2="12"
                y2="12"></line><line x1="12" y1="16" x2="12" y2="16"
              ></line></svg
            >
            <span id="gen-error-msg"
              >Something went wrong. Please try again.</span
            >
          </div>

          <button
            id="btn-generate"
            class="btn-glow w-full py-5 rounded-2xl text-lg"
            disabled
            aria-disabled="true"
            aria-describedby="gen-hint"
          >
            Generate My Website Design →
          </button>
          <p
            id="gen-hint"
            class="text-center text-xs text-[var(--on-surface-variant)] mt-3"
          >
            Takes around 15 seconds · Free · No account needed
          </p>
        </div>
      </div><!-- /glass card -->
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ
  ════════════════════════════════════════════ -->
  <section class="py-28 px-6 md:px-10 bg-[var(--surface-container-low)]/30">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16 reveal-on-scroll">
        <h2 class="font-headline text-4xl font-bold mb-4">Common Questions</h2>
        <p class="text-[var(--on-surface-variant)]">
          Everything you need to know about the WebCraft process.
        </p>
      </div>

      <div class="grid gap-4">
        {
          [
            {
              q: "Do I actually own the website?",
              a: "Yes. Once the human-build phase is complete and your final payment is made, you own the website, the code, and the domain (if we registered it for you) outright. No monthly 'rent' for your own digital property.",
            },
            {
              q: "How does the 'Human-Built' part work?",
              a: "The AI creates the visual blueprint and content strategy. Our Dublin-based developers then take that mockup and build it using professional, high-performance code (not a clunky drag-and-drop builder) to ensure it's lightning-fast and SEO-ready.",
            },
            {
              q: "Can I change things in the design later?",
              a: "Absolutely. The mockup is a starting point. During the proposal stage and build phase, you'll have a dedicated project manager to ensure every detail is exactly how you want it.",
            },
            {
              q: "Is there really no obligation to buy?",
              a: "None at all. Generating a design and receiving a proposal is 100% free. We only start work if you're thrilled with the design and choose to move forward with the fixed-price quote.",
            },
          ].map((item) => (
            <div class="bg-[var(--surface-container)] p-6 md:p-8 rounded-2xl border border-[var(--outline-variant)]/10 reveal-on-scroll">
              <h3 class="font-headline text-xl font-bold mb-3 text-[var(--on-surface)]">
                {item.q}
              </h3>
              <p class="text-[var(--on-surface-variant)] leading-relaxed text-sm md:text-base">
                {item.a}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOOTER
  ════════════════════════════════════════════ -->
  <footer
    class="bg-[#080a12] border-t border-[var(--outline-variant)]/10 py-10 px-6 md:px-10"
  >
    <div
      class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <img src={logo.src} alt="WebCraft Logo" class="h-10 w-auto" />
      <nav aria-label="Footer navigation">
        <ul
          class="flex gap-6 text-xs text-[var(--on-surface-variant)] uppercase tracking-widest font-bold list-none"
        >
          <li>
            <a
              href="/testimonials"
              class="hover:text-[var(--on-surface)] transition-colors"
              >Client Stories</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="hover:text-[var(--on-surface)] transition-colors"
              >About Us</a
            >
          </li>
          <li>
            <a
              href="/privacy"
              class="hover:text-[var(--on-surface)] transition-colors"
              >Privacy</a
            >
          </li>
          <li>
            <a
              href="/terms"
              class="hover:text-[var(--on-surface)] transition-colors">Terms</a
            >
          </li>
          <li>
            <a
              href="/contact"
              class="hover:text-[var(--on-surface)] transition-colors"
              >Contact</a
            >
          </li>
        </ul>
      </nav>
      <p class="text-xs text-[var(--outline)]">
        © 2025 WebCraft. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>

<!-- ═══════════════════════════════════════════
     MAIN CONTENT ANCHOR (skip link target)
════════════════════════════════════════════ -->
<div id="main-content" tabindex="-1" style="outline:none;"></div>

<script>
  import { saveBrief } from "../lib/session";

  // ── State ──────────────────────────────────────────────────
  let selectedTrade = "";
  let selectedGoal = "";
  let selectedVibe = "";

  // ── DOM refs ───────────────────────────────────────────────
  const generateBtn = document.getElementById(
    "btn-generate",
  ) as HTMLButtonElement;
  const tradeOther = document.getElementById("trade-other") as HTMLInputElement;
  const bizNameInput = document.getElementById("biz-name") as HTMLInputElement;
  const bizLocInput = document.getElementById(
    "biz-location",
  ) as HTMLInputElement;
  const uspInput = document.getElementById("usp-input") as HTMLInputElement;
  const srStatus = document.getElementById("sr-status") as HTMLElement;
  const errorBanner = document.getElementById(
    "gen-error-banner",
  ) as HTMLElement;
  const errorMsg = document.getElementById("gen-error-msg") as HTMLElement;
  const bizNameError = document.getElementById("biz-name-error") as HTMLElement;
  const bizLocError = document.getElementById("biz-loc-error") as HTMLElement;

  // ── Announce to screen readers ─────────────────────────────
  function announce(msg: string) {
    srStatus.textContent = "";
    requestAnimationFrame(() => {
      srStatus.textContent = msg;
    });
  }

  // ── Show/hide error banner ─────────────────────────────────
  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorBanner.classList.add("visible");
    errorBanner.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }
  function clearError() {
    errorBanner.classList.remove("visible");
  }

  // ── Progressive disclosure ─────────────────────────────────
  // Uses hidden attribute (valid HTML) rather than display:none class
  // Trigger: only after blur (leaving the field), not mid-keystroke
  function revealStep(id: string) {
    const el = document.getElementById(id);
    if (!el) return;

    const isHidden = el.hasAttribute("hidden");
    if (isHidden) {
      el.removeAttribute("hidden");
    }

    // Use a delay to allow the CSS animation/layout to start
    // and provide a more deliberate, high-end scroll feel.
    setTimeout(
      () => {
        el.scrollIntoView({
          behavior: "smooth",
          block: "center",
        });
      },
      isHidden ? 250 : 50,
    );
  }

  // ── Validate — enable/disable generate ────────────────────
  function validate() {
    const bizName = bizNameInput.value.trim();
    const bizLoc = bizLocInput.value.trim();
    const isValid = !!(
      selectedTrade &&
      bizName &&
      bizLoc &&
      selectedGoal &&
      selectedVibe
    );
    generateBtn.disabled = !isValid;
    generateBtn.setAttribute("aria-disabled", String(!isValid));
  }

  // ── Trade pills ────────────────────────────────────────────
  const tradePills =
    document.querySelectorAll<HTMLButtonElement>(".trade-pill");
  tradePills.forEach((pill) => {
    pill.addEventListener("click", () => {
      tradePills.forEach((p) => {
        p.classList.remove("selected");
        p.setAttribute("aria-pressed", "false");
      });
      pill.classList.add("selected");
      pill.setAttribute("aria-pressed", "true");
      selectedTrade = pill.dataset.trade ?? "";
      tradeOther.value = "";
      validate();
      announce(`Trade selected: ${selectedTrade}`);
      revealStep("step-2");
    });
  });

  tradeOther.addEventListener("blur", () => {
    const val = tradeOther.value.trim();
    if (!val) return;
    tradePills.forEach((p) => {
      p.classList.remove("selected");
      p.setAttribute("aria-pressed", "false");
    });
    selectedTrade = val;
    validate();
    revealStep("step-2");
  });
  tradeOther.addEventListener("input", () => {
    // Keep state in sync but don't trigger disclosure mid-keystroke
    selectedTrade = tradeOther.value.trim();
    validate();
  });

  // ── Business name & Location — reveal Q3 on blur with valid values ─────
  function checkStep2Completion() {
    const nameVal = bizNameInput.value.trim();
    const locVal = bizLocInput.value.trim();

    if (nameVal && locVal) {
      validate();
      revealStep("step-3");
    }
  }

  bizNameInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      bizNameInput.blur(); // Triggers the blur validation
      if (bizNameInput.value.trim()) {
        bizLocInput.focus();
      }
    }
  });

  bizLocInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      bizLocInput.blur(); // Triggers the blur validation/progression
    }
  });

  bizNameInput.addEventListener("blur", () => {
    const val = bizNameInput.value.trim();
    if (!val) {
      bizNameInput.setAttribute("aria-invalid", "true");
      bizNameError.classList.add("visible");
    } else {
      bizNameInput.removeAttribute("aria-invalid");
      bizNameError.classList.remove("visible");
    }
    checkStep2Completion();
  });

  bizLocInput.addEventListener("blur", () => {
    const val = bizLocInput.value.trim();
    if (!val) {
      bizLocInput.setAttribute("aria-invalid", "true");
      bizLocError.classList.add("visible");
    } else {
      bizLocInput.removeAttribute("aria-invalid");
      bizLocError.classList.remove("visible");
    }
    checkStep2Completion();
  });

  bizNameInput.addEventListener("input", () => {
    if (bizNameInput.value.trim()) {
      bizNameInput.removeAttribute("aria-invalid");
      bizNameError.classList.remove("visible");
    }
    validate();
  });

  bizLocInput.addEventListener("input", () => {
    if (bizLocInput.value.trim()) {
      bizLocInput.removeAttribute("aria-invalid");
      bizLocError.classList.remove("visible");
    }
    validate();
  });

  // ── Goal tiles ─────────────────────────────────────────────
  const goalTiles = document.querySelectorAll<HTMLElement>("[data-goal]");
  goalTiles.forEach((tile) => {
    tile.addEventListener("click", () => {
      goalTiles.forEach((t) => t.classList.remove("selected"));
      tile.classList.add("selected");
      const radio = tile.querySelector<HTMLInputElement>('input[type="radio"]');
      if (radio) radio.checked = true;
      selectedGoal = tile.dataset.goal ?? "";
      validate();
      announce(
        `Goal selected: ${tile.querySelector(".font-bold")?.textContent?.trim()}`,
      );
      revealStep("step-4");
    });
    // Keyboard: space/enter on the label triggers the click
  });

  // ── Vibe tiles ─────────────────────────────────────────────
  const vibeTiles = document.querySelectorAll<HTMLElement>("[data-vibe]");
  vibeTiles.forEach((tile) => {
    tile.addEventListener("click", () => {
      vibeTiles.forEach((t) => t.classList.remove("selected"));
      tile.classList.add("selected");
      const radio = tile.querySelector<HTMLInputElement>('input[type="radio"]');
      if (radio) radio.checked = true;
      selectedVibe = tile.dataset.vibe ?? "";
      validate();
      announce(
        `Style selected: ${tile.querySelector(".font-bold")?.textContent?.trim()}`,
      );
      revealStep("step-5");
    });
  });

  // ── Generate ───────────────────────────────────────────────
  function startGenerate() {
    if (generateBtn.disabled) return;
    clearError();

    const brief = {
      trade: selectedTrade,
      businessName: bizNameInput.value.trim(),
      location: bizLocInput.value.trim() || "UK",
      goal: selectedGoal,
      vibe: selectedVibe,
      usp: uspInput.value.trim(),
    };

    // Persist with expiry
    saveBrief(brief);

    // Button loading state — prevents double-click
    generateBtn.disabled = true;
    generateBtn.setAttribute("aria-disabled", "true");
    generateBtn.textContent = "Preparing your design…";

    // Redirect
    window.location.href = "/finalise";
  }

  generateBtn.addEventListener("click", startGenerate);

  // ── Scroll helpers ─────────────────────────────────────────
  function scrollToGenerate() {
    document.getElementById("generate")?.scrollIntoView({ behavior: "smooth" });
  }
  document
    .getElementById("hero-generate-btn")
    ?.addEventListener("click", scrollToGenerate);
  document
    .getElementById("steps-generate-btn")
    ?.addEventListener("click", scrollToGenerate);
  document
    .getElementById("nav-build-btn")
    ?.addEventListener("click", scrollToGenerate);

  // ── Scroll reveal observer ─────────────────────────────────
  const observer = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("visible");
      }),
    { threshold: 0.1 },
  );
  document
    .querySelectorAll(".reveal-on-scroll")
    .forEach((el) => observer.observe(el));
</script>
