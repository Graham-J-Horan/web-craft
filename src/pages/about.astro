---
import Layout from '../layouts/Layout.astro';
import logo from '../assets/web_craft_logo.svg';
import '../styles/global.css';
---

<Layout
  title="About Us — WebCraft"
  description="Learn about the team behind WebCraft. A small team in Dublin passionate about merging AI intelligence with human design."
>
  <div class="min-h-screen flex flex-col" style="background:#080a12;">

    <!-- NAV -->
    <nav
      aria-label="Main navigation"
      class="fixed top-0 w-full z-50 glass border-b border-[var(--outline-variant)]/10 flex justify-between items-center px-6 md:px-10"
      style="height:var(--nav-height);"
    >
      <a href="/" aria-label="WebCraft — return to home">
        <img src={logo.src} alt="WebCraft" class="h-12 w-auto" />
      </a>

      <div class="hidden md:flex items-center gap-8 text-sm">
        <a href="/#how-it-works" class="text-[var(--on-surface-variant)] hover:text-[var(--on-surface)] transition-colors">How it works</a>
        <a href="/#generate"     class="text-[var(--on-surface-variant)] hover:text-[var(--on-surface)] transition-colors">Generate</a>
        <a href="/about"         class="text-[var(--on-surface)] font-bold transition-colors" aria-current="page">About Us</a>
      </div>

      <a href="/#generate" class="btn-glow px-5 py-2.5 rounded-full text-sm" style="text-decoration:none;display:inline-flex;align-items:center;">
        Build My Site
      </a>
    </nav>

    <!-- MAIN -->
    <main
      id="main-content"
      tabindex="-1"
      class="flex-1 px-6 md:px-10 max-w-5xl mx-auto w-full"
      style="padding-top:calc(var(--nav-height) + 5rem); padding-bottom:5rem;"
    >
      <!-- Hero -->
      <section class="mb-20 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-[var(--tertiary)] text-xs font-bold uppercase tracking-widest mb-6" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);">
          Based in Dublin, Ireland
        </div>
        <h1 class="font-headline text-5xl md:text-7xl font-bold mb-8 tracking-tight">
          Where AI intelligence meets<br/>
          <span class="grad-primary">human craftsmanship.</span>
        </h1>
        <p class="text-[var(--on-surface-variant)] text-xl leading-relaxed max-w-3xl mx-auto">
          We are a small team with an unending passion for design and web development. We believe the future of the web isn't just automated — it's augmented.
        </p>
      </section>

      <!-- Cards -->
      <div class="grid md:grid-cols-2 gap-8 mb-20">
        <div class="bg-[var(--surface-container)] p-8 rounded-[2rem] border border-[var(--outline-variant)]/10">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-6" style="background:rgba(16,185,129,0.2);" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h2 class="font-headline text-2xl font-bold mb-4">Our Mission</h2>
          <p class="text-[var(--on-surface-variant)] leading-relaxed">
            Founded in the heart of Dublin, WebCraft was born from a simple observation: small businesses need professional websites faster than traditional agencies can build them, but higher quality than generic templates can provide.
          </p>
        </div>

        <div class="bg-[var(--surface-container-high)] p-8 rounded-[2rem] border border-[var(--outline-variant)]/10">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-6" style="background:rgba(110,231,183,0.2);" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--tertiary)" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <h2 class="font-headline text-2xl font-bold mb-4">The Model</h2>
          <p class="text-[var(--on-surface-variant)] leading-relaxed">
            Our "AI-Designed, Human-Built" approach uses cutting-edge reasoning models to understand your trade's unique requirements, generating a bespoke mockup in seconds. Once you love the design, our human experts turn that vision into a high-performance, live website.
          </p>
        </div>
      </div>

      <!-- Passion section -->
      <section aria-labelledby="passion-heading" class="p-10 md:p-16 rounded-[3rem] border border-[var(--outline-variant)]/10 relative overflow-hidden" style="background:linear-gradient(135deg,var(--surface-container-low),var(--surface));">
        <div aria-hidden="true" class="absolute top-0 right-0 w-64 h-64 blur-[100px] pointer-events-none" style="background:rgba(16,185,129,0.05);"></div>
        <div class="relative z-10 max-w-2xl">
          <h2 id="passion-heading" class="font-headline text-3xl md:text-4xl font-bold mb-6">Unending Passion</h2>
          <p class="text-[var(--on-surface-variant)] text-lg leading-relaxed mb-8">
            We don't just ship code; we craft digital experiences. Every pixel, transition, and line of text is scrutinised by our Dublin-based team to ensure it meets our standard of excellence. We are obsessed with the intersection of aesthetic beauty and technical performance.
          </p>
          <div class="flex items-center gap-4">
            <div class="flex -space-x-3" aria-hidden="true">
              <div class="w-10 h-10 rounded-full border-2" style="border-color:#080a12;background:linear-gradient(135deg,#064e3b,#10b981);"></div>
              <div class="w-10 h-10 rounded-full border-2" style="border-color:#080a12;background:linear-gradient(135deg,#10b981,#34d399);"></div>
              <div class="w-10 h-10 rounded-full border-2" style="border-color:#080a12;background:linear-gradient(135deg,#34d399,#6ee7b7);"></div>
            </div>
            <span class="text-sm font-bold text-[var(--on-surface)] tracking-wide">The Dublin Crew</span>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--outline-variant)]/10 py-10 px-6 md:px-10">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <img src={logo.src} alt="WebCraft" class="h-10 w-auto" />
        <p class="text-xs text-[var(--outline)]">&copy; 2025 WebCraft. All rights reserved. Built with passion in Dublin.</p>
      </div>
    </footer>
  </div>
</Layout>
