---
import "../styles/global.css";
---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'WebCraft — Your Website, Designed by AI. Built by Us.',
  description = 'Answer 4 questions. Get a bespoke AI-generated website mockup for your trade in seconds. Love it — lock it in and receive your no-obligation proposal within 72 hours.',
} = Astro.props as Props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://webcraft.ai');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0c0e17" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content="/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content="/og-image.png" />

    <!--
      Fonts — loaded ONCE here. Never import or link fonts in child pages.
      Using display=swap for performance (text renders in fallback while font loads).
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!--
      Global styles — Astro resolves this import correctly at build time.
      Do NOT use href="/src/styles/global.css" — that only works in dev.
    -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Skip to main content — required for keyboard/AT users -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>

<!--
  is:global so these classes work across all slotted child pages.
  Only put things here that are truly layout-level (skip link, sr-only).
  Everything else lives in global.css imported via Astro's import in each page.
-->
<style is:global>
  .skip-link {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
    text-decoration: none;
  }
  .skip-link:focus {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 10000;
    width: auto;
    height: auto;
    padding: 0.5rem 1rem;
    margin: 0;
    overflow: visible;
    clip: auto;
    white-space: normal;
    background: #10b981;
    color: #0c0e17;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 0.875rem;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
